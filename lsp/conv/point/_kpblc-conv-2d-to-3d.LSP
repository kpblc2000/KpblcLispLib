(defun _kpblc-conv-2d-to-3d (point)
                            ;|
*    ѕреобразование 2ƒ-точки в 3ƒ
*    ѕараметры вызова:
*  point  список вещественных чисел (точка)
*    ѕримеры вызова:
(_kpblc-conv-2d-to-3d (getpoint))
|;
  (list (car point)
        (cadr point)
        (cond ((caddr point))
              (t 0.0)
        ) ;_ end of cond
  ) ;_ end of list
) ;_ end of defun
